# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=           # Resend dashboard → Webhooks → Delivery events endpoint
RESEND_INBOUND_WEBHOOK_SECRET=   # Resend dashboard → Inbound → Webhook secret

# Email sender
# Must be a verified Resend sending domain. For custom per-broker domains, set up Resend domain verification per broker.
FROM_EMAIL=noreply@hollisai.com.au
REPLY_TO_EMAIL=replies@hollisai.com.au

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron
CRON_SECRET=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Feedback
FEEDBACK_EMAIL=
